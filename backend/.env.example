PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/eventms
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
# Local dev: localhost. On Render, you can set your real site URL(s) (comma-separated). The production Netlify URL is always allowed by the API even if this stays localhost.
CLIENT_URL=http://localhost:5173
