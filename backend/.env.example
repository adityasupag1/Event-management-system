PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/eventms
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
# Local dev: localhost. On Render you may set real frontend URL(s). The production Netlify URL is always allowed; use ALLOWED_ORIGINS for extra sites (comma-separated).
CLIENT_URL=http://localhost:5173
# Optional: comma-separated extra origins (e.g. Netlify deploy previews).
# ALLOWED_ORIGINS=https://deploy-preview-1--your-site.netlify.app
